    { name:"Casino Flottant",           emoji:"🎲", employee:"Croupier en chef",    baseCost:2.4e14, baseIncome:3.6e12,click:2e12,  goal:1.8e14 },
    { name:"Rooftop Infinity",          emoji:"🌌", employee:"Mixologue",           baseCost:1.6e15, baseIncome:2.4e13,click:1.3e13,goal:1.2e15 },
    { name:"Île Privée",                emoji:"🏖️", employee:"Garde forestier",     baseCost:1.1e16, baseIncome:1.6e14,click:9e13,  goal:8e15 },
    { name:"Suite Présidentielle Océan",emoji:"👑", employee:"Chef de protocole",   baseCost:7.5e16, baseIncome:1.1e15,click:6e14,  goal:5.5e16 },
  ];

  const HOTELS = [
    {
      name: "Hôtel Excelsior",
      subtitle: "Idle Tycoon",
      floors: HOTEL1_FLOORS,
      theme: {
        "--navy":"#0b1220", "--navy-light":"#161f37", "--navy-card":"#1b2540",
        "--gold":"#d4af37", "--gold-soft":"#f0d98c", "--cream":"#f3ecd9",
        "--muted":"#8a93ad", "--green":"#3f8f6f", "--green-soft":"#2a4a3d",
        "--burgundy":"#8a3245", "--line":"rgba(212,175,55,0.18)"
      }
    },
    {
      name: "Riviera Palace",
      subtitle: "Prestige Tycoon",
      floors: HOTEL2_FLOORS,
      theme: {
        "--navy":"#04201f", "--navy-light":"#0a3534", "--navy-card":"#0f4544",
        "--gold":"#2dd4bf", "--gold-soft":"#7ef0e3", "--cream":"#eafffb",
        "--muted":"#7fb8b3", "--green":"#3f8f6f", "--green-soft":"#2a4a3d",
        "--burgundy":"#ef6f5b", "--line":"rgba(45,212,191,0.22)"
      }
    },
  ];

  let FLOORS = HOTELS[0].floors; // réaffecté dynamiquement à chaque changement d'hôtel

  const EMPLOYEE_GROWTH = 1.15;     // +15% de coût par employé embauché
  const COMPLETION_BONUS = 1.10;    // +10% de revenus globaux par étage terminé
  const HOTEL_MONEY_BOOST = 1.15;   // +15% d'argent offert au passage vers le nouvel hôtel
  const OFFLINE_EFFICIENCY = 0.5;   // 50% des revenus gagnés pendant l'absence
  const OFFLINE_CAP_HOURS = 8;
  const SAVE_KEY = "hotel-tycoon-save";

  // ---- Anti auto-clicker ----
  const AUTOCLICK_MAX_CPS = 13;         // le message apparaît à partir de 14 clics/seconde
  const AUTOCLICK_WINDOW_MS = 1000;    // fenêtre glissante d'1 seconde
  const WARNING_DURATION = 10;         // secondes d'affichage du message (clics bloqués pendant ce temps)
  const MAX_WARNINGS = 15;             // avertissements avant reset

  // ---- Auto-clic "officiel" du jeu (récompensé par pub) ----
  const POWERUP_AUTOCLICK_DURATION_MS = 60 * 1000; // dure 1 minute
  const POWERUP_AUTOCLICK_RATE_MS = 100;           // 10 clics / seconde (= la limite autorisée)
  const AD_DURATION_SEC = 5;                       // durée de la fausse pub

  // Le bouton revient soit 30 min, soit 1h après son utilisation, au hasard.
  function randomPowerupDelay(){
    const minutes = Math.random() < 0.5 ? 30 : 60;
    return minutes * 60 * 1000;
  }

  let state = {
    money: 20,
    activeFloor: 0,
    globalMult: 1,
    floors: FLOORS.map((f, i) => ({ unlocked: i === 0, employees: 0, completed: false })),
    warningCount: 0,
    nextPowerupTime: Date.now() + randomPowerupDelay(),
    totalEarned: 0,
    currentHotel: 0,
    hotelCompletionHandled: false,
    hotelsCompleted: 0,
  };

  let storageAvailable = true;
  let clickTimestamps = [];
  let warningActive = false;
  let warningInterval = null;
  let officialAutoClickActive = false;
  let officialAutoClickTimer = null;

  // ---------------- Helpers ----------------
  function formatMoney(n){
    const sign = n < 0 ? "-" : "";
    n = Math.abs(n);
    if(n < 1000) return sign + n.toFixed(n < 10 ? 1 : 0) + " €";
    const units = [
      [1e12, "Md€"], [1e9, "Md€"], [1e6, "M€"], [1e3, "K€"]
    ];
    if(n >= 1e9) return sign + (n/1e9).toFixed(2) + " Md€";
    if(n >= 1e6) return sign + (n/1e6).toFixed(2) + " M€";
    return sign + (n/1e3).toFixed(2) + " K€";
  }

  const HIRE_COST_MULTIPLIER = 1.5; // embaucher coûte 50% plus cher

  function employeeCost(floorIdx){
    const f = FLOORS[floorIdx];
    const owned = state.floors[floorIdx].employees;
    return Math.ceil(f.baseCost * HIRE_COST_MULTIPLIER * Math.pow(EMPLOYEE_GROWTH, owned));
  }

  function floorIncome(floorIdx){
    const f = FLOORS[floorIdx];
    const fs = state.floors[floorIdx];
    if(!fs.unlocked) return 0;
    return f.baseIncome * fs.employees * (1 + fs.employees * 0.05);
  }

  const PASSIVE_INCOME_MULTIPLIER = 0.7; // revenus par seconde réduits de 30%

  function totalIncomePerSecond(){
    let sum = 0;
    for(let i=0;i<FLOORS.length;i++) sum += floorIncome(i);
    return sum * state.globalMult * PASSIVE_INCOME_MULTIPLIER;
  }

  function nextLockedIndex(){
    for(let i=0;i<FLOORS.length;i++) if(!state.floors[i].unlocked) return i;
    return -1;
  }

  // ---------------- Actions ----------------
  function clickActiveFloor(){
    if(warningActive) return; // clics bloqués pendant l'affichage de l'avertissement
    const i = state.activeFloor;
    const f = FLOORS[i];
    const fs = state.floors[i];
    if(!fs.unlocked) return;
    if(recordClick()) return; // ce clic vient de dépasser la limite -> bloqué, pas de gain
    const gain = f.click * state.globalMult;
    state.money += gain;
    state.totalEarned += gain;
    spawnFloatText("+" + formatMoney(gain));
    render();
  }

  function hireForActiveFloor(){
    const i = state.activeFloor;
    const fs = state.floors[i];
    if(!fs.unlocked) return;
    const cost = employeeCost(i);
    if(state.money >= cost){
      state.money -= cost;
      fs.employees += 1;
      render();
    }
  }

  function selectFloor(i){
    const fs = state.floors[i];
    if(fs.unlocked){
      state.activeFloor = i;
      render();
      return;
    }
    if(i === nextLockedIndex()){
      const prev = FLOORS[i-1];
      const prevIncome = floorIncome(i-1);
      showToast("🔒 Termine " + prev.name + " (" + formatMoney(prevIncome) + "/" + formatMoney(prev.goal) + " €/s) — il s'ouvrira automatiquement");
    } else {
      showToast("🔒 Débloque d'abord les étages précédents");
    }
  }

  function checkCompletions(){
    syncFloorUnlocks();
    for(let i=0;i<FLOORS.length;i++){
      const f = FLOORS[i];
      const fs = state.floors[i];
      if(fs.unlocked && !fs.completed && floorIncome(i) >= f.goal){
        fs.completed = true;
        state.globalMult *= COMPLETION_BONUS;
        if(i === FLOORS.length - 1){
          if(!state.hotelCompletionHandled){
            state.hotelCompletionHandled = true;
            triggerHotelCompletionCelebration();
          }
        } else {
          showToast("✅ " + f.name + " terminé ! Revenus globaux +10%");
        }
        syncFloorUnlocks();
        renderBuilding();
      }
    }
  }

  // Garantit que tout étage marqué "terminé" a bien son étage suivant débloqué,
  // même si cet état "terminé" provient d'une ancienne sauvegarde.
  function syncFloorUnlocks(){
    for(let i=0;i<FLOORS.length-1;i++){
      if(state.floors[i].completed && !state.floors[i+1].unlocked){
        state.floors[i+1].unlocked = true;
        state.activeFloor = i+1;
        showToast("🏗️ " + FLOORS[i+1].name + " est maintenant ouvert !");
      }
    }
  }

  function triggerHotelCompletionCelebration(){
    const overlay = document.getElementById("htg-celebrate");
    const titleEl = document.getElementById("htg-celebrate-title");
    const subEl = document.getElementById("htg-celebrate-sub");
    const bonusEl = document.getElementById("htg-celebrate-bonus");
    const btn = document.getElementById("htg-celebrate-close");
    const currentName = HOTELS[state.currentHotel].name;
    const hasNext = state.currentHotel + 1 < HOTELS.length;

    document.getElementById("htg-celebrate-stat").textContent =
      "Tu as généré un total de " + formatMoney(state.totalEarned) + " depuis le début de l'aventure.";

    titleEl.textContent = currentName + " élevé au rang de 6 étoiles";

    if(hasNext){
      const next = HOTELS[state.currentHotel + 1];
      subEl.textContent = "Une distinction jamais accordée à aucun autre établissement... et une nouvelle opportunité t'attend ailleurs.";
      bonusEl.textContent = "🧳 Direction le " + next.name + " — +15% d'argent offert au départ";
      btn.textContent = "Découvrir " + next.name + " →";
      btn.onclick = () => {
        overlay.style.display = "none";
        advanceToNextHotel();
      };
    } else {
      subEl.textContent = "Une distinction jamais accordée à aucun autre établissement au monde — ton hôtel entre dans la légende.";
      bonusEl.textContent = "🏆 Bonus légendaire permanent : revenus ×2";
      state.globalMult *= 2;
      btn.textContent = "Continuer l'aventure";
      btn.onclick = () => {
        overlay.style.display = "none";
      };
    }

    state.hotelsCompleted += 1;
    spawnConfetti();
    overlay.style.display = "flex";
  }

  function applyHotelTheme(hotelIdx){
    const root = document.getElementById("htg-app");
    const theme = HOTELS[hotelIdx].theme;
    for(const key in theme){
      root.style.setProperty(key, theme[key]);
    }
  }

  function updateBrandDisplay(){
    document.getElementById("htg-brand-name").textContent = HOTELS[state.currentHotel].name;
    document.getElementById("htg-brand-sub").textContent = HOTELS[state.currentHotel].subtitle;
  }

  function advanceToNextHotel(){
    const nextIdx = state.currentHotel + 1;
    if(nextIdx >= HOTELS.length) return;

    state.currentHotel = nextIdx;
    FLOORS = HOTELS[nextIdx].floors;
    state.floors = FLOORS.map((f, i) => ({ unlocked: i === 0, employees: 0, completed: false }));
    state.activeFloor = 0;
    state.hotelCompletionHandled = false;
    state.money *= HOTEL_MONEY_BOOST;

    applyHotelTheme(nextIdx);
    updateBrandDisplay();
    showToast("🏨 Bienvenue au " + HOTELS[nextIdx].name + " !");
    render();
    renderBuilding();
    saveGame();
  }

  function spawnConfetti(){
    const wrap = document.getElementById("htg-confetti");
    wrap.innerHTML = "";
    const colors = ["#d4af37", "#f0d98c", "#8a3245", "#3f8f6f", "#f3ecd9"];
    for(let k=0; k<46; k++){
      const piece = document.createElement("div");
      piece.className = "htg-confetti-piece";
      piece.style.left = (Math.random()*100) + "%";
      piece.style.background = colors[Math.floor(Math.random()*colors.length)];
      piece.style.animationDuration = (2.4 + Math.random()*2) + "s";
      piece.style.animationDelay = (Math.random()*1.2) + "s";
      wrap.appendChild(piece);
    }
  }

  // ---------------- Détection d'auto-clicker ----------------
  // Règle : le jeu autorise jusqu'à 10 clics/seconde (c'est exactement le rythme de
  // l'auto-clic officiel ci-dessous). Tous les clics comptent dans le même compteur,
  // qu'ils viennent d'un vrai clic, de l'auto-clic du jeu, ou d'un outil externe :
  // si le total dépasse 10/s (ex. un auto-clicker externe utilisé EN PLUS de celui
  // du jeu), l'avertissement se déclenche et bloque tous les clics pendant 10s.
  function recordClick(){
    const now = Date.now();
    clickTimestamps.push(now);
    const cutoff = now - AUTOCLICK_WINDOW_MS;
    clickTimestamps = clickTimestamps.filter(t => t > cutoff);
    if(clickTimestamps.length > AUTOCLICK_MAX_CPS){
      triggerWarning();
      clickTimestamps = [];
      return true;
    }
    return false;
  }

  function triggerWarning(){
    state.warningCount += 1;
    warningActive = true;
    let secondsLeft = WARNING_DURATION;

    const banner = document.getElementById("htg-warning");
    const timeEl = document.getElementById("htg-warning-time");
    const countEl = document.getElementById("htg-warning-count");
    const clickBtn = document.getElementById("htg-btn-click");

    banner.style.display = "flex";
    clickBtn.disabled = true;
    timeEl.textContent = secondsLeft + "s";
    countEl.textContent = "Avertissement " + state.warningCount + "/" + MAX_WARNINGS + " — clics bloqués";

    if(warningInterval) clearInterval(warningInterval);
    warningInterval = setInterval(() => {
      secondsLeft -= 1;
      timeEl.textContent = Math.max(secondsLeft, 0) + "s";
      if(secondsLeft <= 0){
        clearInterval(warningInterval);
        banner.style.display = "none";
        warningActive = false;
        clickBtn.disabled = false;
        if(state.warningCount >= MAX_WARNINGS){
          performAutoclickReset();
        }
      }
    }, 1000);
  }

  function performAutoclickReset(){
    resetGame();
    showToast("🚫 Progression réinitialisée : trop d'utilisation d'auto-clicker");
  }

  // ---------------- Auto-clic "officiel" (récompense pub) ----------------
  function checkPowerupAvailability(){
    if(officialAutoClickActive) return;
    const btn = document.getElementById("htg-powerup-btn");
    if(Date.now() >= state.nextPowerupTime){
      btn.style.display = "block";
    }
  }

  function onPowerupClick(){
    document.getElementById("htg-powerup-btn").style.display = "none";
    showFakeAd(() => {
      activateOfficialAutoClick();
      state.nextPowerupTime = Date.now() + randomPowerupDelay();
      saveGame();
    });
  }

  // Pub simulée. Pour une vraie pub, remplace le contenu de cette fonction par
  // l'appel au SDK du réseau publicitaire (ex. AdMob côté mobile) et appelle
  // onComplete() dans son callback "reward received".
  function showFakeAd(onComplete){
    const overlay = document.getElementById("htg-adoverlay");
    const timerEl = document.getElementById("htg-adtimer");
    const closeBtn = document.getElementById("htg-adclose");
    overlay.style.display = "flex";
    closeBtn.disabled = true;
    let t = AD_DURATION_SEC;
    timerEl.textContent = t;

    const interval = setInterval(() => {
      t -= 1;
      timerEl.textContent = t > 0 ? t : "✓";
      if(t <= 0){
        clearInterval(interval);
        closeBtn.disabled = false;
      }
    }, 1000);

    closeBtn.onclick = () => {
      overlay.style.display = "none";
      onComplete();
    };
  }

  function activateOfficialAutoClick(){
    officialAutoClickActive = true;
    showToast("🤖 Auto-clic du jeu activé pendant 1 minute !");
    let elapsed = 0;
    officialAutoClickTimer = setInterval(() => {
      clickActiveFloor();
      elapsed += POWERUP_AUTOCLICK_RATE_MS;
      if(elapsed >= POWERUP_AUTOCLICK_DURATION_MS){
        clearInterval(officialAutoClickTimer);
        officialAutoClickActive = false;
        showToast("✅ Auto-clic du jeu terminé");
      }
    }, POWERUP_AUTOCLICK_RATE_MS);
  }

  // ---------------- Rendering ----------------
  function spawnFloatText(text){
    const zone = document.getElementById("htg-clickzone");
    const el = document.createElement("div");
    el.className = "htg-float";
    el.textContent = text;
    el.style.left = (45 + Math.random()*10) + "%";
    el.style.top = "8px";
    zone.appendChild(el);
    setTimeout(()=> el.remove(), 950);
  }

  function showToast(msg){
    const wrap = document.getElementById("htg-toasts");
    const el = document.createElement("div");
    el.className = "htg-toast";
    el.textContent = msg;
    wrap.appendChild(el);
    setTimeout(()=> el.remove(), 3900);
  }

  function render(){
    document.getElementById("htg-money").textContent = formatMoney(state.money);
    document.getElementById("htg-income").textContent = "+" + formatMoney(totalIncomePerSecond()) + "/s";
    document.getElementById("htg-sixstar-badge").style.display = state.hotelsCompleted > 0 ? "inline" : "none";

    const i = state.activeFloor;
    const f = FLOORS[i];
    const fs = state.floors[i];
    const income = floorIncome(i);
    const pct = Math.min(100, (income / f.goal) * 100);

    document.getElementById("htg-active-emoji").textContent = f.emoji;
    document.getElementById("htg-active-name").textContent = f.name;
    document.getElementById("htg-active-sub").textContent = fs.employees + " " + f.employee.toLowerCase() + (fs.employees === 1 ? "" : "s") + " · " + formatMoney(income) + "/s";

    const fillEl = document.getElementById("htg-progress-fill");
    fillEl.style.width = pct + "%";
    fillEl.classList.toggle("done", fs.completed);
    document.getElementById("htg-progress-pct").textContent = fs.completed ? "Terminé ✓" : Math.floor(pct) + "%";
    document.getElementById("htg-progress-text").textContent = fs.completed ? "Étage terminé" : "Objectif : " + formatMoney(f.goal) + "/s";

    document.getElementById("htg-click-value").textContent = "+" + formatMoney(f.click * state.globalMult);
    const hireBtn = document.getElementById("htg-btn-hire");
    const cost = employeeCost(i);
    document.getElementById("htg-hire-cost").textContent = formatMoney(cost);
    hireBtn.disabled = state.money < cost;
  }

  function renderBuilding(){
    const wrap = document.getElementById("htg-building");
    wrap.innerHTML = "";
    const nextIdx = nextLockedIndex();

    // affichage du dernier étage en haut, du hall en bas (vue "bâtiment")
    for(let i = FLOORS.length - 1; i >= 0; i--){
      const f = FLOORS[i];
      const fs = state.floors[i];
      const row = document.createElement("div");
      row.className = "htg-floor-row" +
        (fs.unlocked ? "" : (i === nextIdx ? " buyable" : " locked")) +
        (i === state.activeFloor && fs.unlocked ? " active" : "") +
        (fs.completed ? " completed" : "");

      const emoji = document.createElement("div");
      emoji.className = "htg-row-emoji";
      emoji.textContent = fs.unlocked ? f.emoji : "🔒";
      row.appendChild(emoji);

      const mid = document.createElement("div");
      mid.className = "htg-row-mid";
      const nameEl = document.createElement("div");
      nameEl.className = "htg-row-name";
      nameEl.textContent = f.name;
      mid.appendChild(nameEl);
      const incEl = document.createElement("div");
      incEl.className = "htg-row-income";
      incEl.textContent = fs.unlocked ? formatMoney(floorIncome(i)) + "/s" : "verrouillé";
      mid.appendChild(incEl);
      row.appendChild(mid);

      const right = document.createElement("div");
      right.className = "htg-row-right";
      if(fs.completed){
        right.innerHTML = '<span class="htg-check">✓</span>';
      } else if(!fs.unlocked && i === nextIdx){
        right.classList.add("unlock-cost");
        const prevIncome = floorIncome(i-1);
        right.textContent = formatMoney(prevIncome) + "/" + formatMoney(FLOORS[i-1].goal);
      } else if(!fs.unlocked){
        right.textContent = "—";
      }
      row.appendChild(right);

      row.addEventListener("click", () => selectFloor(i));
      wrap.appendChild(row);
    }
  }

  // ---------------- Save / Load ----------------
  async function saveGame(){
    if(!storageAvailable) return;
    try{
      const payload = JSON.stringify({ ...state, lastSave: Date.now() });
      const result = await window.storage.set(SAVE_KEY, payload);
      if(!result) storageAvailable = false;
    }catch(e){
      console.error("Échec de la sauvegarde :", e);
      storageAvailable = false;
    }
  }

  async function loadGame(){
    try{
      const result = await window.storage.get(SAVE_KEY);
      if(result && result.value){
        const saved = JSON.parse(result.value);
        state.money = saved.money;
        state.activeFloor = saved.activeFloor;
        state.globalMult = saved.globalMult;
        state.floors = saved.floors;
        state.warningCount = saved.warningCount || 0;
        state.nextPowerupTime = saved.nextPowerupTime || (Date.now() + randomPowerupDelay());
        state.totalEarned = saved.totalEarned || 0;
        state.sixStarAchieved = saved.sixStarAchieved || false;

        const elapsedMs = Date.now() - (saved.lastSave || Date.now());
        const elapsedSec = Math.min(elapsedMs / 1000, OFFLINE_CAP_HOURS * 3600);
        if(elapsedSec > 30){
          const gain = totalIncomePerSecond() * elapsedSec * OFFLINE_EFFICIENCY;
          state.money += gain;
          state.totalEarned += gain;
          const hours = (elapsedSec/3600).toFixed(1);
          showToast("👋 Bon retour ! +" + formatMoney(gain) + " gagnés pendant " + hours + "h d'absence");
        }
      }
    }catch(e){
      // pas de sauvegarde existante ou stockage indisponible — on démarre une nouvelle partie
      console.log("Nouvelle partie (pas de sauvegarde trouvée).");
    }
  }

  async function resetGame(){
    state = {
      money: 20,
      activeFloor: 0,
      globalMult: 1,
      floors: FLOORS.map((f, i) => ({ unlocked: i === 0, employees: 0, completed: false })),
      warningCount: 0,
      nextPowerupTime: Date.now() + randomPowerupDelay(),
      totalEarned: 0,
      sixStarAchieved: false,
    };
    clickTimestamps = [];
    warningActive = false;
    if(warningInterval) clearInterval(warningInterval);
    document.getElementById("htg-warning").style.display = "none";
    document.getElementById("htg-celebrate").style.display = "none";
    document.getElementById("htg-btn-click").disabled = false;
    document.getElementById("htg-powerup-btn").style.display = "none";
    try{ await window.storage.delete(SAVE_KEY); }catch(e){}
    render();
    renderBuilding();
  }

  // ---------------- Game loop ----------------
  let lastTick = performance.now();
  function tick(){
    const now = performance.now();
    const dt = (now - lastTick) / 1000;
    lastTick = now;
    const passive = totalIncomePerSecond() * dt;
    state.money += passive;
    state.totalEarned += passive;
    checkCompletions();
    render();
    requestAnimationFrame(tick);
  }

  // ---------------- Init ----------------
  document.getElementById("htg-btn-click").addEventListener("click", clickActiveFloor);
  document.getElementById("htg-btn-hire").addEventListener("click", hireForActiveFloor);
  document.getElementById("htg-powerup-btn").addEventListener("click", onPowerupClick);
  document.getElementById("htg-ad-cta").addEventListener("click", () => {
    showToast("🎭 C'est une pub simulée, rien à installer ici !");
  });

  loadGame().then(() => {
    syncFloorUnlocks();
    render();
    renderBuilding();
    requestAnimationFrame(tick);
    setInterval(saveGame, 5000);
    setInterval(checkPowerupAvailability, 1000);
    setInterval(renderBuilding, 300);
    checkPowerupAvailability();
  });

})();
</script>
