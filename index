<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap');

:root{
  --navy: #0b1220;
  --navy-light: #161f37;
  --navy-card: #1b2540;
  --gold: #d4af37;
  --gold-soft: #f0d98c;
  --cream: #f3ecd9;
  --muted: #8a93ad;
  --green: #3f8f6f;
  --green-soft: #2a4a3d;
  --burgundy: #8a3245;
  --line: rgba(212,175,55,0.18);
}

*{ box-sizing:border-box; }

.htg-app{
  background: radial-gradient(1200px 600px at 50% -10%, #1a2745 0%, var(--navy) 55%) var(--navy);
  color: var(--cream);
  font-family:'Inter', sans-serif;
  padding: 18px;
  display:flex;
  flex-direction:column;
  gap:16px;
  max-width: 560px;
  margin: 0 auto;
}

.htg-topbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding: 14px 18px;
  background: linear-gradient(180deg, var(--navy-card), var(--navy-light));
  border: 1px solid var(--line);
  border-radius: 14px;
}
.htg-brand{
  font-family:'Playfair Display', serif;
  font-weight:800;
  font-size: 19px;
  letter-spacing: 0.3px;
  color: var(--gold-soft);
}
.htg-brand-sub{ color: var(--cream); font-weight:600; font-size:11px; display:block; letter-spacing:1.5px; text-transform:uppercase; opacity:0.6; margin-top:2px;}
.htg-sixstar-badge{
  display:none;
  margin-left:8px;
  font-size:10.5px;
  font-weight:700;
  color: var(--gold);
  background: rgba(212,175,55,0.15);
  border: 1px solid var(--gold);
  border-radius: 6px;
  padding: 2px 6px;
  vertical-align: middle;
  letter-spacing: 0.5px;
}
.htg-stats{ text-align:right; }
.htg-money{ font-size:20px; font-weight:700; color: var(--gold-soft); font-family:'Playfair Display', serif;}
.htg-income{ font-size:12px; color: var(--muted); margin-top:2px;}

.htg-panel{
  background: linear-gradient(180deg, var(--navy-card), var(--navy-light));
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 20px;
  position: relative;
  overflow:hidden;
}
.htg-panel::before{
  content:"";
  position:absolute; inset:0;
  background: linear-gradient(120deg, transparent 40%, rgba(212,175,55,0.06) 50%, transparent 60%);
  pointer-events:none;
}
.htg-floor-head{ display:flex; align-items:center; gap:12px; margin-bottom:14px; }
.htg-floor-emoji{ font-size:34px; }
.htg-floor-name{ font-family:'Playfair Display', serif; font-size:21px; font-weight:700; color:var(--cream); }
.htg-floor-sub{ font-size:12px; color:var(--muted); margin-top:2px; }

.htg-progress-wrap{ margin: 12px 0 16px; }
.htg-progress-label{ display:flex; justify-content:space-between; font-size:11px; color:var(--muted); margin-bottom:5px; }
.htg-progress-bar{ height:8px; border-radius:6px; background: rgba(255,255,255,0.06); overflow:hidden; }
.htg-progress-fill{ height:100%; background: linear-gradient(90deg, var(--gold), var(--gold-soft)); transition: width 0.3s ease; }
.htg-progress-fill.done{ background: linear-gradient(90deg, var(--green), #5fc79a); }

.htg-row-2{ display:flex; gap:10px; }
.htg-btn{
  flex:1;
  border:none;
  border-radius: 12px;
  padding: 13px 10px;
  font-family:'Inter', sans-serif;
  font-weight:700;
  font-size: 13px;
  cursor:pointer;
  transition: transform 0.08s ease, filter 0.15s ease;
  color: var(--navy);
}
.htg-btn:active{ transform: scale(0.97); }
.htg-btn-click{
  background: linear-gradient(180deg, var(--gold-soft), var(--gold));
  box-shadow: 0 0 0 1px rgba(212,175,55,0.4), 0 8px 18px -8px rgba(212,175,55,0.6);
  font-size:14px;
}
.htg-btn-hire{
  background: linear-gradient(180deg, #cfd6e8, #aab3cf);
}
.htg-btn:disabled{
  filter: grayscale(0.6) brightness(0.55);
  cursor: not-allowed;
}
.htg-btn small{ display:block; font-weight:500; opacity:0.75; font-size:11px; margin-top:2px;}

.htg-click-zone{ position:relative; }
.htg-float{
  position:absolute;
  left:50%;
  top:0;
  font-weight:700;
  color: var(--gold-soft);
  font-size: 14px;
  pointer-events:none;
  animation: htgFloat 0.9s ease-out forwards;
  white-space:nowrap;
}
@keyframes htgFloat{
  0%{ opacity:1; transform: translate(-50%, 0); }
  100%{ opacity:0; transform: translate(-50%, -42px); }
}

.htg-list-title{ font-size:11px; text-transform:uppercase; letter-spacing:1.5px; color:var(--muted); margin: 4px 4px 8px; }
.htg-building{
  display:flex;
  flex-direction:column;
  gap:8px;
  max-height: 320px;
  overflow-y:auto;
  padding-right: 2px;
  scrollbar-width: thin;
  scrollbar-color: rgba(212,175,55,0.35) transparent;
}
.htg-building::-webkit-scrollbar{ width:5px; }
.htg-building::-webkit-scrollbar-track{ background:transparent; }
.htg-building::-webkit-scrollbar-thumb{ background: rgba(212,175,55,0.35); border-radius:4px; }
.htg-floor-row{
  display:flex;
  align-items:center;
  gap:10px;
  padding: 10px 12px;
  border-radius:12px;
  background: var(--navy-card);
  border: 1px solid var(--line);
  cursor:pointer;
  transition: border-color 0.15s ease, background 0.15s ease;
}
.htg-floor-row:hover{ border-color: rgba(212,175,55,0.4); }
.htg-floor-row.active{ border-color: var(--gold); background: linear-gradient(90deg, rgba(212,175,55,0.12), transparent); }
.htg-floor-row.locked{ opacity:0.55; cursor: default; }
.htg-floor-row.buyable{
  opacity:1;
  cursor:pointer;
  border-color: var(--gold);
  border-style: dashed;
  animation: htgPulse 1.8s ease-in-out infinite;
}
@keyframes htgPulse{
  0%,100%{ box-shadow: 0 0 0 0 rgba(212,175,55,0.25); }
  50%{ box-shadow: 0 0 0 4px rgba(212,175,55,0.12); }
}
.htg-floor-row.completed{ border-color: rgba(63,143,111,0.6); }
.htg-row-emoji{ font-size:20px; width:26px; text-align:center; }
.htg-row-mid{ flex:1; min-width:0; }
.htg-row-name{ font-size:13px; font-weight:600; }
.htg-row-income{ font-size:11px; color:var(--muted); }
.htg-row-right{ font-size:11px; text-align:right; color:var(--muted); white-space:nowrap; }
.htg-row-right.unlock-cost{ color: var(--gold-soft); font-weight:700; }
.htg-check{ color: #5fc79a; font-size:16px; }
.htg-lock{ font-size:14px; }

.htg-toasts{
  position: fixed;
  bottom: 18px;
  left: 50%;
  transform: translateX(-50%);
  display:flex;
  flex-direction:column;
  gap:8px;
  z-index: 50;
  width: calc(100% - 36px);
  max-width: 524px;
  pointer-events:none;
}
.htg-toast{
  background: linear-gradient(180deg, var(--navy-card), var(--navy-light));
  border: 1px solid var(--gold);
  color: var(--gold-soft);
  font-size: 13px;
  font-weight:600;
  padding: 10px 14px;
  border-radius: 10px;
  text-align:center;
  animation: htgToastIn 0.25s ease, htgToastOut 0.4s ease 3.4s forwards;
  box-shadow: 0 10px 30px -10px rgba(0,0,0,0.6);
}
@keyframes htgToastIn{ from{ opacity:0; transform: translateY(8px);} to{opacity:1; transform: translateY(0);} }
@keyframes htgToastOut{ to{ opacity:0; transform: translateY(-6px); } }

.htg-footer-note{ font-size:10.5px; color:var(--muted); text-align:center; padding: 2px 8px 0; }
.htg-reset{ background:none; border:none; color:var(--muted); text-decoration:underline; cursor:pointer; font-size:10.5px; font-family:inherit; }

.htg-warning{
  display:flex;
  flex-direction:column;
  gap:5px;
  background: linear-gradient(180deg, var(--burgundy), #5e1c28);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 12px;
  padding: 12px 16px;
}
.htg-warning-text{ font-weight:700; font-size:13px; color:#fff; }
.htg-warning-meta{ display:flex; justify-content:space-between; font-size:11.5px; color:rgba(255,255,255,0.85); }

.htg-powerup-btn{
  border:none;
  border-radius:12px;
  padding:13px;
  font-family:'Inter', sans-serif;
  font-weight:700;
  font-size:13px;
  cursor:pointer;
  background: linear-gradient(180deg, var(--gold-soft), var(--gold));
  color: var(--navy);
  animation: htgPulse 1.8s ease-in-out infinite;
}

.htg-adoverlay{
  display:none;
  position:fixed;
  inset:0;
  background: rgba(0,0,0,0.78);
  z-index:100;
  align-items:center;
  justify-content:center;
  padding:20px;
}
.htg-adbox{
  background: linear-gradient(180deg, var(--navy-card), var(--navy-light));
  border:1px solid var(--gold);
  border-radius:18px;
  padding:0;
  max-width:320px;
  width:100%;
  overflow:hidden;
}
.htg-ad-videoarea{
  position:relative;
  height:360px;
  background: linear-gradient(150deg, #2b3a63, #141d33 60%, #0b1220);
  display:flex;
  align-items:center;
  justify-content:center;
}
.htg-ad-tag{
  position:absolute; top:10px; left:10px;
  background: rgba(255,255,255,0.16);
  color:#fff;
  font-size:10px;
  font-weight:700;
  padding:3px 9px;
  border-radius:6px;
  letter-spacing:0.4px;
}
.htg-ad-countdown{
  position:absolute; top:10px; right:10px;
  width:28px; height:28px;
  border-radius:50%;
  border:2px solid rgba(255,255,255,0.55);
  display:flex; align-items:center; justify-content:center;
  font-size:12px; font-weight:700; color:#fff;
  background: rgba(0,0,0,0.3);
}
.htg-ad-icon{ font-size:62px; opacity:0.9; animation: htgAdFloat 2.4s ease-in-out infinite; }
@keyframes htgAdFloat{ 0%,100%{ transform: translateY(0); } 50%{ transform: translateY(-10px); } }

.htg-ad-promo{
  display:flex;
  align-items:center;
  gap:10px;
  padding:12px 14px;
  background: rgba(255,255,255,0.04);
  border-top:1px solid var(--line);
}
.htg-ad-promo-icon{
  width:42px; height:42px;
  border-radius:11px;
  background: linear-gradient(160deg, var(--gold-soft), var(--burgundy));
  display:flex; align-items:center; justify-content:center;
  font-size:21px;
  flex-shrink:0;
}
.htg-ad-promo-info{ flex:1; min-width:0; }
.htg-ad-promo-name{ font-size:13px; font-weight:700; color:var(--cream); }
.htg-ad-promo-rating{ font-size:11px; color:var(--muted); margin-top:2px; }
.htg-ad-promo-cta{
  border:none; border-radius:8px; padding:8px 14px;
  font-size:12px; font-weight:700;
  background: #3f8f6f; color:#fff; cursor:pointer; flex-shrink:0;
}
.htg-ad-claim{
  display:block; width:calc(100% - 28px); margin:14px;
  border:none; border-radius:10px; padding:12px;
  font-weight:700; font-family:'Inter', sans-serif;
  background: var(--gold); color:var(--navy); cursor:pointer;
}
.htg-ad-claim:disabled{ filter:grayscale(0.6) brightness(0.6); cursor:not-allowed; }

.htg-adclose{
  border:none;
  border-radius:10px;
  padding:11px 26px;
  font-weight:700;
  font-family:'Inter', sans-serif;
  background: var(--gold);
  color: var(--navy);
  cursor:pointer;
}
.htg-adclose:disabled{ filter:grayscale(0.6) brightness(0.6); cursor:not-allowed; }

.htg-celebrate{
  display:none;
  position:fixed;
  inset:0;
  background: radial-gradient(circle at 50% 28%, rgba(212,175,55,0.18), rgba(0,0,0,0.86));
  z-index:200;
  align-items:center;
  justify-content:center;
  padding:20px;
  overflow:hidden;
}
.htg-confetti{ position:absolute; inset:0; pointer-events:none; overflow:hidden; }
.htg-confetti-piece{
  position:absolute;
  top:-12px;
  width:8px;
  height:14px;
  opacity:0.9;
  animation-name: htgConfettiFall;
  animation-timing-function: linear;
  animation-fill-mode: forwards;
}
@keyframes htgConfettiFall{
  to{ transform: translateY(112vh) rotate(540deg); opacity:0.25; }
}
.htg-celebrate-box{
  position:relative;
  z-index:1;
  background: linear-gradient(180deg, var(--navy-card), var(--navy-light));
  border:1px solid var(--gold);
  border-radius:20px;
  padding:34px 26px;
  max-width:380px;
  width:100%;
  text-align:center;
  box-shadow: 0 20px 60px -10px rgba(0,0,0,0.7);
}
.htg-celebrate-stars{ font-size:30px; color: var(--gold); letter-spacing:4px; margin-bottom:12px; }
.htg-sixth-star{
  display:inline-block;
  color: var(--gold-soft);
  animation: htgStarPop 0.6s ease 0.4s both, htgStarGlow 1.6s ease-in-out 1.2s infinite;
}
@keyframes htgStarPop{ from{ transform: scale(0) rotate(-90deg); opacity:0; } to{ transform: scale(1) rotate(0); opacity:1; } }
@keyframes htgStarGlow{ 0%,100%{ text-shadow: 0 0 6px rgba(240,217,140,0.4); } 50%{ text-shadow: 0 0 18px rgba(240,217,140,0.9); } }
.htg-celebrate-title{ font-family:'Playfair Display', serif; font-size:20px; font-weight:800; color:var(--cream); margin-bottom:10px; line-height:1.3; }
.htg-celebrate-sub{ font-size:12.5px; color:var(--muted); margin-bottom:16px; line-height:1.45; }
.htg-celebrate-stat{ font-size:13px; color: var(--gold-soft); margin-bottom:8px; }
.htg-celebrate-bonus{ font-size:13px; font-weight:700; color:#5fc79a; margin-bottom:20px; }
</style>

